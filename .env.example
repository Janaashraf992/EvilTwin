# ============================================================================
# EvilTwin SDN Deception Platform - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# All configuration is loaded via Pydantic BaseSettings
# Missing required values will cause the backend to fail at startup

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection settings for storing attacker profiles, session logs, and alerts

# Database host (use 'postgres' for Docker Compose, or IP/hostname for external DB)
POSTGRES_HOST=postgres

# Database port (default PostgreSQL port is 5432)
POSTGRES_PORT=5432

# Database name for EvilTwin data
POSTGRES_DB=eviltwin

# Database username
POSTGRES_USER=eviltwin

# Database password (REQUIRED - use a strong password in production)
POSTGRES_PASSWORD=changeme_strong_password


# ============================================================================
# SDN CONTROLLER CONFIGURATION
# ============================================================================
# Settings for the Ryu-based OpenFlow controller that manages traffic redirection

# Ryu REST API URL for flow management
RYU_REST_URL=http://ryu:8080

# IP address of the honeypot where suspicious traffic will be redirected
HONEYPOT_IP=10.0.2.10

# CIDR block of the real production network (used for routing decisions)
REAL_NET_CIDR=10.0.1.0/24

# Minimum threat level (0-4) required to trigger SDN redirection
# Level 0=unknown, 1=low, 2=medium, 3=high, 4=critical
# Default: 2 (redirect medium threats and above)
THREAT_REDIRECT_THRESHOLD=2


# ============================================================================
# AI MODEL CONFIGURATION
# ============================================================================
# Settings for the machine learning threat scoring engine

# Path to the trained RandomForest model file (model.pkl)
MODEL_PATH=/app/ai/model.pkl

# Time-to-live (seconds) for cached threat scores per IP address
# Default: 300 seconds (5 minutes)
SCORE_CACHE_TTL=300


# ============================================================================
# EXTERNAL API TOKENS
# ============================================================================
# API keys for VPN detection and IP reputation services

# ipinfo.io API token (REQUIRED)
# Used for: ASN lookup, geolocation, ISP identification
# Get your token at: https://ipinfo.io/signup
IPINFO_TOKEN=your_ipinfo_token_here

# AbuseIPDB API key (REQUIRED)
# Used for: IP reputation scoring, proxy/VPN detection
# Get your key at: https://www.abuseipdb.com/api
ABUSEIPDB_API_KEY=your_abuseipdb_key_here


# ============================================================================
# SPLUNK INTEGRATION
# ============================================================================
# Configuration for forwarding high-threat alerts to Splunk SIEM via HTTP Event Collector

# Splunk HTTP Event Collector (HEC) endpoint URL
# Example: http://splunk.example.com:8088/services/collector/event
# Leave empty to disable Splunk integration
SPLUNK_HEC_URL=http://splunk:8088/services/collector/event

# Splunk HEC authentication token
# Generate in Splunk: Settings > Data Inputs > HTTP Event Collector
# Leave empty to disable Splunk integration
SPLUNK_HEC_TOKEN=your_splunk_hec_token_here


# ============================================================================
# CANARY TOKEN INTEGRATION
# ============================================================================
# Configuration for receiving and validating canary token webhook callbacks

# Shared secret for HMAC-SHA256 signature validation of canary webhooks (REQUIRED)
# This must match the secret configured in your canary token provider
# Use a strong random string (e.g., generated with: openssl rand -hex 32)
CANARY_WEBHOOK_SECRET=your_canary_secret_here


# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
# URLs for the React dashboard to connect to the backend API

# Base URL for backend REST API
# Development: http://localhost:8000
# Production: https://api.eviltwin.example.com
VITE_API_BASE_URL=http://localhost:8000

# JWT Authentication Config
SECRET_KEY=your_super_secret_jwt_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# WebSocket URL for real-time alert streaming
# Development: ws://localhost:8000/ws/alerts
# Production: wss://api.eviltwin.example.com/ws/alerts
VITE_WS_URL=ws://localhost:8000/ws/alerts


# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Comma-separated list of allowed origins for CORS
# Default: http://localhost:5173,http://localhost:3000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000


# ============================================================================
# CANARY REPLAY PROTECTION
# ============================================================================
# Maximum age (seconds) of canary webhook timestamps before they are rejected
# Default: 300 (5 minutes)
CANARY_WEBHOOK_TOLERANCE_SECONDS=300


# ============================================================================
# LLM / AI ASSISTANT CONFIGURATION
# ============================================================================
# OpenAI-compatible LLM for threat analysis and conversational intelligence
# Supports: OpenAI, Azure OpenAI, Ollama, vLLM, LM Studio, etc.

# API key for the LLM provider (leave empty to disable LLM features)
LLM_API_KEY=

# Base URL for the OpenAI-compatible API
# OpenAI:     https://api.openai.com/v1
# Ollama:     http://localhost:11434/v1
# vLLM:       http://localhost:8000/v1
# LM Studio:  http://localhost:1234/v1
LLM_BASE_URL=https://api.openai.com/v1

# Model name to use for analysis
# OpenAI: gpt-4o, gpt-4o-mini, gpt-3.5-turbo
# Ollama: llama3, mistral, etc.
LLM_MODEL=gpt-4o-mini

# Maximum tokens for LLM responses (default: 2048)
LLM_MAX_TOKENS=2048

# Temperature for LLM responses (0.0 = deterministic, 1.0 = creative)
# Lower values recommended for security analysis
LLM_TEMPERATURE=0.2


# ============================================================================
# OPTIONAL CONFIGURATION
# ============================================================================
# Additional settings that have sensible defaults but can be overridden

# Backend API host (default: 0.0.0.0)
# BACKEND_HOST=0.0.0.0

# Backend API port (default: 8000)
# BACKEND_PORT=8000

# Log level (default: INFO)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# Enable debug mode (default: false)
# WARNING: Never enable in production - exposes sensitive information
# DEBUG=false
