# ============================================================================
# EvilTwin Root Environment Template
# ============================================================================
# Copy this file to .env in the repository root before running:
#   cp .env.example .env
#   docker compose up --build -d
#
# The required values below are the only ones you must set for the demo stack.
# Everything else can stay at its default unless you are customizing the setup.

# ============================================================================
# REQUIRED FOR CLONE-AND-RUN
# ============================================================================

# PostgreSQL password used by the compose stack.
POSTGRES_PASSWORD=changeme

# JWT signing secret for dashboard authentication.
# Generate one with: openssl rand -hex 32
SECRET_KEY=change-me-in-production

# Shared HMAC secret for Canary webhook validation.
# Generate one with: openssl rand -hex 32
CANARY_WEBHOOK_SECRET=change-me-in-production


# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=eviltwin
POSTGRES_USER=eviltwin


# ============================================================================
# SDN / HONEYPOT ROUTING
# ============================================================================

RYU_REST_URL=http://ryu:8080
HONEYPOT_IP=10.0.2.10
REAL_NET_CIDR=10.0.1.0/24
THREAT_REDIRECT_THRESHOLD=2


# ============================================================================
# AI MODEL CONFIGURATION
# ============================================================================

MODEL_PATH=/app/ai/model.pkl
SCORE_CACHE_TTL=300


# ============================================================================
# OPTIONAL EXTERNAL TOKENS
# ============================================================================

# Leave blank to disable IP enrichment and reputation lookups.
IPINFO_TOKEN=
ABUSEIPDB_API_KEY=


# ============================================================================
# OPTIONAL SPLUNK FORWARDING
# ============================================================================

SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=


# ============================================================================
# AUTH / API SETTINGS
# ============================================================================

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CANARY_WEBHOOK_TOLERANCE_SECONDS=300


# ============================================================================
# OPTIONAL LLM / INCIDENT NARRATIVES
# ============================================================================

# Leave blank to disable AI narrative features. Works with OpenAI-compatible APIs.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.2


# ============================================================================
# FRONTEND RUNTIME URLS
# ============================================================================

VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/alerts


# ============================================================================
# DEMO ACCOUNT BOOTSTRAP
# ============================================================================

# The docker compose stack enables demo bootstrap by default so teammates can
# log in immediately after cloning.
DEMO_BOOTSTRAP=true
DEMO_USER_EMAIL=analyst@eviltwin.local
DEMO_USER_PASSWORD=eviltwin-demo
DEMO_USER_ROLE=analyst


# ============================================================================
# OPTIONAL DIONAEA DEMO PORT OVERRIDES
# ============================================================================

DIONAEA_FTP_PORT=2121
DIONAEA_HTTP_PORT=8081
DIONAEA_SMB_PORT=1445
DIONAEA_MSSQL_PORT=11433


# ============================================================================
# OPTIONAL APP OVERRIDES
# ============================================================================

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO
DEBUG=false
